<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProductStore</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/UserWeb.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    @{
        var authToken = Context.Request.Cookies["auth_token"];
        var authEmail = Context.Request.Cookies["auth_email"];
        var isAuthenticated = !string.IsNullOrWhiteSpace(authToken);
    }
    <header class="site-header">
        <nav class="main-nav container">
            <a class="brand-logo" asp-area="" asp-controller="Home" asp-action="Index">CLOTHES STORE</a>

            <ul class="nav-center">
                <li><a asp-controller="Product" asp-action="Shop" asp-route-category="Men">Men</a></li>
                <li><a asp-controller="Product" asp-action="Shop" asp-route-category="Women">Women</a></li>
                <li><a asp-controller="Product" asp-action="Shop" asp-route-category="Collection">Collection</a></li>
                <li><a asp-controller="Product" asp-action="Shop" asp-route-sort="price-asc">Sale</a></li>
            </ul>

            <div class="nav-right">
                <form asp-controller="Product" asp-action="Shop" method="get" class="nav-search-form" role="search">
                    <input type="text"
                           name="search"
                           value="@Context.Request.Query["search"]"
                           class="nav-search-input"
                           placeholder="Search product"
                           aria-label="Search product" />
                    <button type="submit" class="nav-search-btn" aria-label="Submit search">
                        <i class="fas fa-search"></i>
                    </button>
                </form>
                <a asp-controller="Product" asp-action="Wishlist" aria-label="Wishlist" class="nav-icon-link" id="navWishlistLink">
                    <i class="far fa-heart"></i>
                    <span class="nav-badge" id="wishlistBadge"></span>
                </a>
                <a asp-controller="Product" asp-action="Cart" aria-label="Cart" class="nav-icon-link" id="navCartLink">
                    <i class="fas fa-shopping-bag"></i>
                    <span class="nav-badge" id="cartBadge"></span>
                </a>
                <details class="account-menu">
                    <summary aria-label="Account"><i class="far fa-user"></i></summary>
                    <div class="account-dropdown">
                        @if (isAuthenticated)
                        {
                            <p class="account-email">@authEmail</p>
                            <a asp-controller="Product" asp-action="Cart" class="account-link">Giỏ hàng</a>
                            <a asp-controller="Product" asp-action="Wishlist" class="account-link">Yêu thích</a>
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="account-link">Logout</button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="account-link">Login</a>
                            <a asp-controller="Account" asp-action="Register" class="account-link">Register</a>
                        }
                        <a href="https://localhost:7082" class="account-link">Admin Site</a>
                    </div>
                </details>
            </div>
        </nav>
    </header>

    <main role="main" class="page-content">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container footer-grid">
            <div>
                <p class="footer-brand">CLOTHES STORE</p>
            </div>
            <div class="footer-links">
                <a asp-controller="Home" asp-action="Index">About</a>
                <a asp-controller="Home" asp-action="Privacy">Contact</a>
                <a asp-controller="Home" asp-action="Privacy">Policy</a>
            </div>
            <div class="footer-links">
                <a href="https://instagram.com" target="_blank" rel="noreferrer">Instagram</a>
                <a href="https://facebook.com" target="_blank" rel="noreferrer">Facebook</a>
            </div>
        </div>
        <div class="container footer-copy">
            <span>&copy; @DateTime.Now.Year Clothes Store</span>
        </div>
    </footer>

    <div id="toast-container" class="toast-container"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
