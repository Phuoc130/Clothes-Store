@model IEnumerable<Product>
@{
    ViewData["Title"] = "Spring 2026";
}

<section class="hero-banner reveal-on-scroll">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <p class="hero-eyebrow">New Collection</p>
        <h1>Spring 2026</h1>
        <a asp-controller="Product" asp-action="Shop" class="cta-btn">Shop Now</a>
    </div>
</section>

<section class="section-space container reveal-on-scroll">
    <div class="section-header">
        <h2>Categories</h2>
    </div>
    <div class="category-grid">
        <a class="category-card" asp-controller="Product" asp-action="Shop" asp-route-category="Men">
            <img loading="lazy" src="https://images.unsplash.com/photo-1483985988355-763728e1935b?q=80&w=1400&auto=format&fit=crop" alt="Men collection" />
            <span>Shop Men</span>
        </a>
        <a class="category-card" asp-controller="Product" asp-action="Shop" asp-route-category="Women">
            <img loading="lazy" src="https://images.unsplash.com/photo-1524504388940-b1c1722653e1?q=80&w=1400&auto=format&fit=crop" alt="Women collection" />
            <span>Shop Women</span>
        </a>
        <a class="category-card" asp-controller="Product" asp-action="Shop" asp-route-category="Accessories">
            <img loading="lazy" src="https://images.unsplash.com/photo-1506152983158-b4a74a01c721?q=80&w=1400&auto=format&fit=crop" alt="Accessories collection" />
            <span>Shop Accessories</span>
        </a>
    </div>
</section>

<section class="section-space container reveal-on-scroll">
    <div class="section-header split">
        <h2>Featured Products</h2>
        <a asp-controller="Product" asp-action="Shop" class="text-link">View All</a>
    </div>
    <div class="featured-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var p in Model)
            {
                var frontImage = string.IsNullOrWhiteSpace(p.ImageUrl)
                    ? "https://images.unsplash.com/photo-1434389677669-e08b4cac3105?q=80&w=1200&auto=format&fit=crop"
                    : p.ImageUrl;
                var backImage = string.IsNullOrWhiteSpace(p.HoverImageUrl)
                    ? frontImage
                    : p.HoverImageUrl;

                <article class="product-item">
                    <a asp-controller="Product" asp-action="Details" asp-route-id="@p.Product_ID" class="product-image-wrap">
                        <img loading="lazy" class="product-front" src="@frontImage" alt="@p.Name" />
                        <img loading="lazy" class="product-hover" src="@backImage" alt="@p.Name alternate" />
                    </a>
                    <div class="product-meta">
                        <h3>@p.Name</h3>
                        <p>@p.Price.ToString("N0") VND</p>
                    </div>
                </article>
            }
        }
        else
        {
            <p>No featured products available.</p>
        }
    </div>
</section>

<section class="campaign-banner reveal-on-scroll">
    <div class="campaign-overlay"></div>
    <div class="campaign-content">
        <p>Minimal Collection</p>
        <a asp-controller="Product" asp-action="Shop" class="cta-btn cta-btn-light">Explore</a>
    </div>
</section>

<section class="section-space section-narrow reveal-on-scroll">
    <div class="brand-story">
        <h2>Brand Story</h2>
        <p>We create minimal fashion for modern lifestyle. Each silhouette is crafted for clarity, comfort, and everyday elegance.</p>
        <a asp-controller="Product" asp-action="Admin" class="text-link">Manage Products (CRUD)</a>
    </div>
</section>


